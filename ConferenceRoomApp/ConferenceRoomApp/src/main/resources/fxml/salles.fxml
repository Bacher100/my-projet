<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.conference.controller.SallesController"
      spacing="15" style="-fx-padding: 25; -fx-background-color: #f0f2f5;">

    <Label text="Gestion des Salles" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnNouvelleSalle" text="+ Nouvelle salle" styleClass="btn-primary"/>
        <Button fx:id="btnModifier" text="✏ Modifier" styleClass="btn-secondary"/>
        <Button fx:id="btnDesactiver" text="✖ Désactiver" styleClass="btn-danger"/>
        <TextField fx:id="searchField" promptText="Rechercher..." prefWidth="200"/>
    </HBox>

    <TableView fx:id="tableSalles" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNom" text="Nom" prefWidth="180"/>
            <TableColumn fx:id="colCapacite" text="Capacité" prefWidth="100"/>
            <TableColumn fx:id="colLocalisation" text="Localisation" prefWidth="180"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="250"/>
            <TableColumn fx:id="colActive" text="Active" prefWidth="80"/>
        </columns>
    </TableView>
</VBox>
