<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.reservation.controller.LoginController"
           style="-fx-background-color: linear-gradient(to bottom right, #1565C0, #42A5F5);">

    <VBox alignment="CENTER" spacing="0"
          maxWidth="420" maxHeight="520"
          style="-fx-background-color: white; -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 8);">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 40 40 30 40;
              -fx-background-color: #1565C0; -fx-background-radius: 16 16 0 0;">
            <Label text="🏢" style="-fx-font-size: 48;"/>
            <Label text="Gestion des Salles" style="-fx-text-fill: white;
                   -fx-font-size: 20; -fx-font-weight: bold;"/>
            <Label text="Système de Réservation"
                   style="-fx-text-fill: #90CAF9; -fx-font-size: 13;"/>
        </VBox>

        <!-- Form -->
        <VBox spacing="16" style="-fx-padding: 35 40 40 40;">
            <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
            <TextField fx:id="emailField" promptText="votre@email.com"
                       style="-fx-padding: 10; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-border-color: #ddd;
                              -fx-font-size: 13;"/>

            <Label text="Mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
            <PasswordField fx:id="passwordField" promptText="••••••••"
                           style="-fx-padding: 10; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-border-color: #ddd;
                                  -fx-font-size: 13;"/>

            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill: #e74c3c; -fx-font-size: 12;"/>

            <Button fx:id="loginButton" text="Se connecter" maxWidth="Infinity"
                    style="-fx-background-color: #1565C0; -fx-text-fill: white;
                           -fx-font-size: 14; -fx-font-weight: bold;
                           -fx-padding: 12; -fx-background-radius: 8;
                           -fx-cursor: hand;"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Pas encore de compte ?"
                       style="-fx-text-fill: #666; -fx-font-size: 12;"/>
                <Hyperlink fx:id="registerLink" text="S'inscrire"
                           style="-fx-font-size: 12;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>