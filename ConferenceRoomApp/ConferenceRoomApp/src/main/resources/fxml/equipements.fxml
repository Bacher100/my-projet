<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.conference.controller.EquipementsController"
      spacing="15" style="-fx-padding: 25; -fx-background-color: #f0f2f5;">

    <Label text="Gestion des Équipements" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnNouvelEquipement" text="+ Nouvel équipement" styleClass="btn-primary"/>
        <Button fx:id="btnModifier" text="✏ Modifier" styleClass="btn-secondary"/>
        <Button fx:id="btnSignalerDefaut" text="⚠ Signaler défaut" styleClass="btn-danger"/>
        <TextField fx:id="searchField" promptText="Rechercher..." prefWidth="200"/>
    </HBox>

    <TableView fx:id="tableEquipements" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNom" text="Nom" prefWidth="180"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="250"/>
            <TableColumn fx:id="colQuantite" text="Quantité" prefWidth="100"/>
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>
